{
  "buildCommand": "cd artifacts/craka-osint && npx vite build --config vite.config.ts",
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "outputDirectory": "artifacts/craka-osint/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://websitecraka1.onrender.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
